{
  "uid": "navi-digest",
  "title": "Navi — Digest Service",
  "description": "P0 health and log visibility for the navi-digest service",
  "tags": ["navi"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "title": "System Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 2,
      "title": "Service Alive",
      "description": "Green if navi-digest has emitted a log line in the last 2 minutes",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container_name=~\"navi-digest.*\"}[2m]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "noValue": "0"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Alive",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Requests (1h)",
      "description": "HTTP request count via OTEL SDK → Prometheus remote write. Label: job=navi-digest",
      "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(http_server_request_duration_seconds_count{job=\"navi-digest\"}[1h]))",
          "legendFormat": "",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "noValue": "0"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Errors (1h)",
      "description": "Count of ERROR-level log lines in the last hour",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({container_name=~\"navi-digest.*\"} | json | level=\"ERROR\" [1h]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "noValue": "0"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 6,
      "title": "Log Stream",
      "type": "logs",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container_name=~\"navi-digest.*\"} | json",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
